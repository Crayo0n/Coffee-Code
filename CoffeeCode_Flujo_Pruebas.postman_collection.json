{
  "info": {
    "name": "CoffeeCode Flujo de Pruebas",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Paso 0: Iniciar Sesión",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.access_token) {",
              "    pm.collectionVariables.set(\"jwt_token\", jsonData.access_token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "username",
              "value": "mau.mesero@coffeecode.com",
              "type": "text"
            },
            {
              "key": "password",
              "value": "123",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Paso 1: Crear Pedido Inicial",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"table_id\": 1,\n  \"notes\": \"El cliente es alérgico a la nuez\",\n  \"detalles\": [\n    {\n      \"product_id\": 1,\n      \"quantity\": 2\n    },\n    {\n      \"product_id\": 5,\n      \"quantity\": 1\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/pedidos",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "pedidos"
          ]
        }
      }
    },
    {
      "name": "Paso 2: Agregar Producto Extra",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "[\n  {\n    \"product_id\": 2,\n    \"quantity\": 1\n  }\n]"
        },
        "url": {
          "raw": "{{base_url}}/pedidos/1/detalles",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "pedidos",
            "1",
            "detalles"
          ]
        }
      }
    },
    {
      "name": "Paso 3: Marcar Producto PREPARADO",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"PREPARADO\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/pedidos/1/detalles/1/status",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "pedidos",
            "1",
            "detalles",
            "1",
            "status"
          ]
        }
      }
    },
    {
      "name": "Paso 4: Pedir la Cuenta",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"POR_COBRAR\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/pedidos/1/status",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "pedidos",
            "1",
            "status"
          ]
        }
      }
    },
    {
      "name": "Paso 5: Caja Cobra Pedido",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"order_id\": 1,\n  \"payment_method\": \"EFECTIVO\",\n  \"tips\": 35.50\n}"
        },
        "url": {
          "raw": "{{base_url}}/ventas/cobrar",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "ventas",
            "cobrar"
          ]
        }
      }
    },
    {
      "name": "Extra: Alerta de Cocina",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Falta Leche Deslactosada\",\n  \"description\": \"Se terminó la leche para los frapés, urge comprar más para el turno vespertino.\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/alertas",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "alertas"
          ]
        }
      }
    }
  ]
}
